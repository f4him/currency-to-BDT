{
  "manifest_version": 3,
  "name": "BD Currency Converter",
  "version": "1.0.0",
  "description": "Hover over any price to see BDT equivalent at live rates.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://v6.exchangerate-api.com/*"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["config.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bd-currency-converter@youremail.com",
      "strict_min_version": "109.0"
    }
  }
}
